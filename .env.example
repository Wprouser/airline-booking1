DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
BETTER_AUTH_SECRET=replace-with-a-random-secret
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173
PORT=3001

# Optional. Real flight-schedule data via AeroDataBox (RapidAPI, free Basic plan — 600
# units/month). Leave unset to use local simulated flights (no signup needed). See README for
# how to get a key.
AERODATABOX_RAPIDAPI_KEY=

# Optional. Powers on-demand live flight status + airport/airline lookups (AviationStack, free
# plan — 100 requests/month). Leave unset and those features just report "not configured". Does
# NOT power flight search — see README for why.
AVIATIONSTACK_API_KEY=
